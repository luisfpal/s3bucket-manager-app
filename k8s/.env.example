# GitHub Container Registry credentials — copy to .env and fill in the real token.
# .env is gitignored; .env.example is committed as a reference.
#
# Create a classic PAT at:
#   https://github.com/settings/tokens/new?scopes=write:packages
# Required scope: write:packages (includes read:packages automatically)
GHCR_TOKEN="ghp_replace_with_your_token"
